\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Intervention experiment design. Phase\nobreakspace  {}1 (baseline) generates captions without modification. Phase\nobreakspace  {}2 (targeted) zeros $k=100$ gender-associated SAE{} features during generation. Phase\nobreakspace  {}3 (random) repeats ablation with randomly selected features 25 times to establish a control distribution. Statistical comparison tests whether targeted ablation produces significantly larger effects than random ablation.}}{7}\protected@file@percent }
\newlabel{fig:intervention}{{2}{7}}
